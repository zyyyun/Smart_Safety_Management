<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 비밀번호가 보일 때 (Checked 상태) -->
    <item
        android:drawable="@drawable/ic_eye_on"
        android:state_checked="true" />
    <!-- 비밀번호가 숨겨졌을 때 (기본 상태) -->
    <item
        android:drawable="@drawable/ic_eye_off" />
</selector>