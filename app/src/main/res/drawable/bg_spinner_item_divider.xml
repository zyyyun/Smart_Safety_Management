<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 선택된 상태 -->
    <item android:state_activated="true">
        <layer-list>
            <!-- 배경색에 드롭다운과 동일한 라운드(8dp) 적용 -->
            <item>
                <shape>
                    <solid android:color="@color/orange400alpha12_orange400alpha36" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
            <!-- 하단 구분선 (양 옆과 위는 -2dp로 숨김) -->
            <item android:top="-2dp" android:left="-2dp" android:right="-2dp">
                <shape>
                    <stroke android:width="1dp" android:color="@color/gray100_gray950" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- 기본 상태 -->
    <item>
        <layer-list>
            <item>
                <shape>
                    <solid android:color="@android:color/transparent" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
            <item android:top="-2dp" android:left="-2dp" android:right="-2dp">
                <shape>
                    <stroke android:width="1dp" android:color="@color/gray100_gray950" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>