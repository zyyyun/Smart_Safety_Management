<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.Smart_Safety_Management"
        parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <item name="android:letterSpacing">0</item>
        <item name="materialButtonStyle">@style/Widget.App.Button</item>

        <!-- 기본 상태바 -->
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- 예외: 주황 상태바 -->
    <style
        name="Theme.Smart_Safety_Management.Status.Orange"
        parent="Theme.Smart_Safety_Management">

        <item name="android:statusBarColor">@color/orange500_gray950</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- 버튼 커스텀 스타일 -->
    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- 텍스트뷰 커스텀 스타일 (필요시 전역 적용) -->
    <style name="Widget.App.TextView" parent="Widget.AppCompat.TextView">
        <item name="android:letterSpacing">0</item>
    </style>
</resources>
