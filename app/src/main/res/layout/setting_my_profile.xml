<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/base">

    <!-- 뒤로가기 버튼 -->
    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="23dp"
        android:layout_height="29dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/icon_back"
        app:tint="@color/gray900_gray50"/>

    <!-- 내정보 텍스트 -->
    <TextView
        android:id="@+id/txt_my_profile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="@font/pretendard_bold"
        android:text="내정보"
        android:letterSpacing="0"
        android:textColor="@color/gray900_gray50"
        android:textSize="24sp"
        app:layout_constraintStart_toEndOf="@id/backButton"
        app:layout_constraintTop_toTopOf="@id/backButton"
        app:layout_constraintBottom_toBottomOf="@id/backButton"/>

    <!-- 프로필 영역 컨테이너 -->
    <FrameLayout
        android:id="@+id/profile_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
        app:layout_constraintTop_toBottomOf="@id/txt_my_profile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 메인 원 프로필 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="112dp"
            android:layout_height="112dp"
            android:backgroundTint="@color/gray50"
            app:cardCornerRadius="56dp"
            app:cardElevation="0dp"
            app:strokeWidth="0.7dp"
            app:cardUseCompatPadding="false"
            app:strokeColor="@color/gray100">

            <ImageView
                android:id="@+id/iv_profile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:paddingTop="24dp"
                android:src="@drawable/profile" />
        </com.google.android.material.card.MaterialCardView>

        <!-- 카메라 원 버튼 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_camera"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="bottom|end"
            android:clickable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:backgroundTint="@color/orange500"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_camera" />
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

    <!-- 내 정보 섹션 컨테이너 -->
    <LinearLayout
        android:id="@+id/container_my_profile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/profile_container">

        <!-- 내 정보 텍스트 -->
        <TextView
            android:id="@+id/txt_my_profile2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/pretendard_medium"
            android:text="내 정보"
            android:letterSpacing="0"
            android:textColor="@color/gray700_gray400"
            android:textSize="16sp"/>

        <!-- 이름 정보 행 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 왼쪽 라벨 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/pretendard_medium"
                android:text="이름"
                android:letterSpacing="0"
                android:textColor="@color/gray800_gray200"
                android:textSize="18sp"/>

            <!-- 오른쪽 값 + 아이콘 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="end|center_vertical">

                <TextView
                    android:id="@+id/tv_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/pretendard_medium"
                    android:text="안정우"
                    android:letterSpacing="0"
                    android:textColor="@color/gray900_gray50"
                    android:textSize="18sp"/>

                <ImageView
                    android:id="@+id/btn_edit_name"
                    android:layout_width="10dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/right_arrow"
                    android:tint="@color/gray600"/>
            </LinearLayout>
        </LinearLayout>

    <!-- 권한 정보 행 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 왼쪽 라벨 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/pretendard_medium"
            android:text="권한"
            android:letterSpacing="0"
            android:textColor="@color/gray800_gray200"
            android:textSize="18sp"/>

        <!-- 오른쪽 값 + 아이콘 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="end|center_vertical">

            <TextView
                android:id="@+id/tv_user_name_authority"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/pretendard_medium"
                android:text="관리자"
                android:letterSpacing="0"
                android:textColor="@color/gray900_gray50"
                android:textSize="18sp"/>

            <ImageView
                android:layout_width="10dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/right_arrow"
                android:tint="@color/gray100_gray950"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 휴대폰 번호 정보 행 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 왼쪽 라벨 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/pretendard_medium"
            android:text="휴대폰 번호"
            android:letterSpacing="0"
            android:textColor="@color/gray800_gray200"
            android:textSize="18sp"/>

        <!-- 오른쪽 값 + 아이콘 (표시 상태) -->
        <LinearLayout
            android:id="@+id/layout_phone_view"
            android:layout_width="281dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end|center_vertical"
            android:orientation="horizontal"
            android:visibility="visible">

            <TextView
                android:id="@+id/tv_user_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/pretendard_medium"
                android:letterSpacing="0"
                android:text="010-1234-1234"
                android:textColor="@color/gray900_gray50"
                android:textSize="18sp" />

            <ImageView
                android:layout_width="10dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/right_arrow"
                android:tint="@color/gray600" />
        </LinearLayout>

        <!-- 오른쪽 값 + 아이콘 (수정 상태) -->
        <LinearLayout
            android:id="@+id/layout_phone_edit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:visibility="gone">

            <!-- 박스 스타일 -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxStrokeColor="@color/gray200_gray800"
                app:hintEnabled="false"
                android:textColorHint="@color/et_hint_color"
                app:boxBackgroundColor="@color/white_gray900"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="1dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_phone_edit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:padding="10dp"
                    android:textSize="16sp"
                    android:text="010-1234-4567"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 체크(확인) 아이콘 -->
            <ImageView
                android:id="@+id/btn_phone_confirm"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_check"
                android:tint="@color/teal500"/>

            <!-- X(취소) 아이콘 -->
            <ImageView
                android:id="@+id/btn_phone_cancel"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_x" />
        </LinearLayout>
    </LinearLayout>

    <!-- 이메일 정보 행 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 왼쪽 라벨 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/pretendard_medium"
            android:text="이메일"
            android:letterSpacing="0"
            android:textColor="@color/gray800_gray200"
            android:textSize="18sp"/>

        <!-- 오른쪽 값 + 아이콘 (표시 상태) -->
        <LinearLayout
            android:id="@+id/layout_email_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:visibility="visible">

            <TextView
                android:id="@+id/tv_user_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/pretendard_medium"
                android:text="happy@gmail.com"
                android:letterSpacing="0"
                android:textColor="@color/gray900_gray50"
                android:textSize="18sp"/>

            <ImageView
                android:id="@+id/btn_edit_email"
                android:layout_width="10dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/right_arrow"
                android:tint="@color/gray600"/>
        </LinearLayout>

        <!-- 오른쪽 값 + 아이콘 (수정 상태) -->
        <LinearLayout
            android:id="@+id/layout_email_edit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxStrokeColor="@color/gray200_gray800"
                app:hintEnabled="false"
                app:boxBackgroundColor="@color/white_gray900"
                app:boxStrokeWidth="1dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_email_edit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:padding="10dp"
                    android:textSize="16sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <ImageView
                android:id="@+id/btn_email_confirm"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_check"
                android:tint="@color/teal500"/>

            <ImageView
                android:id="@+id/btn_email_cancel"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_x" />
        </LinearLayout>
    </LinearLayout>
    </LinearLayout>

    <!-- 회원탈퇴 섹션 컨테이너 -->
    <LinearLayout
        android:id="@+id/container_withdraw"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/container_my_profile">

        <!-- 회원탈퇴 텍스트 -->
        <TextView
            android:id="@+id/txt_withdraw_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/pretendard_medium"
            android:text="회원탈퇴"
            android:letterSpacing="0"
            android:textColor="@color/gray700_gray400"
            android:textSize="16sp"/>

        <!-- 회원 탈퇴하기 정보 행 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 왼쪽 라벨 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/pretendard_medium"
                android:text="회원 탈퇴하기"
                android:letterSpacing="0"
                android:textColor="@color/gray800_gray200"
                android:textSize="18sp"/>

            <!-- 오른쪽 값 + 아이콘 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="end|center_vertical">

                <ImageView
                    android:id="@+id/btn_withdraw"
                    android:layout_width="10dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/right_arrow"
                    android:tint="@color/gray600"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 로그아웃 -->
    <TextView
        android:id="@+id/tv_logout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="21dp"
        android:fontFamily="@font/pretendard_medium"
        android:text="로그아웃"
        android:letterSpacing="0"
        android:textColor="@color/gray400_gray700"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 로그아웃 밑줄 -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/gray400_gray700"
        app:layout_constraintStart_toStartOf="@id/tv_logout"
        app:layout_constraintEnd_toEndOf="@id/tv_logout"
        app:layout_constraintTop_toBottomOf="@id/tv_logout"/>

</androidx.constraintlayout.widget.ConstraintLayout>
