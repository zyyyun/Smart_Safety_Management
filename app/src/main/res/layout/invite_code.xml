<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_round">

    <!-- 제목 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/pretendard_bold"
        android:text="초대코드 입력"
        android:letterSpacing="0"
        android:textColor="@color/gray800_gray200"
        android:textSize="22sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 설명 -->
    <TextView
        android:id="@+id/tv_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/pretendard_medium"
        android:gravity="center"
        android:text="문자로 받은 초대코드가 있으신가요?"
        android:letterSpacing="0"
        android:textColor="@color/gray700_gray400"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <!-- 입력창 -->
    <EditText
        android:id="@+id/et_invite_code"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_edittext"
        android:fontFamily="@font/pretendard_medium"
        android:hint="여기에 초대코드를 입력해주세요."
        android:letterSpacing="0"
        android:inputType="textPassword"
        android:paddingHorizontal="12dp"
        android:textColor="@color/black_white"
        android:textColorHint="@color/et_hint_color"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_desc" />

    <!-- 에러 메시지 -->
    <TextView
        android:id="@+id/tv_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="유효하지 않은 초대 코드입니다."
        android:letterSpacing="0"
        android:textSize="12sp"
        android:textColor="#EF4444"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/et_invite_code"
        app:layout_constraintStart_toStartOf="@id/et_invite_code"
        android:layout_marginTop="6dp"/>

    <!-- 알림 메시지 -->
    <TextView
        android:id="@+id/tv_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_message_rounded"
        android:fontFamily="@font/pretendard_medium"
        android:paddingStart="20dp"
        android:paddingTop="12dp"
        android:paddingEnd="20dp"
        android:paddingBottom="12dp"
        android:text="초대코드는 설정 메뉴에서도 등록할 수 있습니다."
        android:letterSpacing="0"
        android:textColor="#F97316"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_error" />

    <!-- 등록 버튼 -->
    <Button
        android:id="@+id/btn_submit"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="20dp"
        android:backgroundTint="#F97316"
        android:fontFamily="@font/pretendard_semibold"
        android:text="등록하기"
        android:letterSpacing="0"
        android:textColor="@color/white_black"
        android:textSize="18dp"
        android:stateListAnimator="@null"
        app:cornerRadius="7dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_message" />

    <!-- 초대코드없이 진행 텍스트 -->
    <TextView
        android:id="@+id/tv_skip_invite_code"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="@font/pretendard_medium"
        android:text="초대코드없이 진행"
        android:letterSpacing="0"
        android:textColor="@color/gray400_gray700"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_submit" />

</androidx.constraintlayout.widget.ConstraintLayout>
