<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/base">

    <!-- 뒤로가기 버튼 -->
    <ImageButton
        android:id="@+id/imageButton"
        android:layout_width="23dp"
        android:layout_height="29dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/icon_back"
        app:tint="@color/gray_900.gray_50"/>

    <!-- 회원가입 텍스트 -->
    <TextView
        android:id="@+id/sign_up"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="@font/pretendard_bold"
        android:text="회원가입"
        android:textColor="@color/gray_900.gray_50"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="@id/imageButton"
        app:layout_constraintStart_toEndOf="@id/imageButton"
        app:layout_constraintTop_toTopOf="@id/imageButton"/>

    <!-- 근로자 카드형 버튼 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/btn_worker"
        android:layout_width="0dp"
        android:layout_height="92dp"
        android:layout_margin="16dp"
        android:layout_marginTop="32dp"
        android:background="@color/gray_50.gray_900"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imageButton">

        <!-- 왼쪽 아이콘 -->
        <ImageView
            android:id="@+id/icon_worker"
            android:layout_width="38dp"
            android:layout_height="44dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/worker"
            android:clickable="false"
            android:focusable="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 근로자 텍스트 -->
        <TextView
            android:id="@+id/txt_worker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:clickable="false"
            android:focusable="false"
            android:fontFamily="@font/pretendard_bold"
            android:text="근로자"
            android:textColor="@color/black.white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/icon_worker"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 로 가입하기 텍스트 -->
        <TextView
            android:id="@+id/txt_to_worker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:focusable="false"
            android:fontFamily="@font/pretendard_medium"
            android:text="로 가입하기"
            android:textColor="@color/black.white"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/txt_worker"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 오른쪽 화살표 -->
        <ImageView
            android:id="@+id/icon_arrow"
            android:layout_width="35dp"
            android:layout_height="33dp"
            android:clickable="false"
            android:focusable="false"
            android:layout_marginEnd="16dp"
            android:src="@drawable/right_arrow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 관리자 카드형 버튼 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/btn_manager"
        android:layout_width="0dp"
        android:layout_height="92dp"
        android:layout_margin="16dp"
        android:layout_marginTop="180dp"
        android:background="@color/gray_50.gray_900"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_worker">

        <!-- 왼쪽 아이콘 -->
        <ImageView
            android:id="@+id/icon_manager"
            android:layout_width="38dp"
            android:layout_height="44dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/manager"
            android:clickable="false"
            android:focusable="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 근로자 텍스트 -->
        <TextView
            android:id="@+id/txt_manager"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:clickable="false"
            android:focusable="false"
            android:fontFamily="@font/pretendard_bold"
            android:text="관리자"
            android:textColor="@color/black.white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/icon_manager"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 로 가입하기 텍스트 -->
        <TextView
            android:id="@+id/txt_to_manager"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:focusable="false"
            android:fontFamily="@font/pretendard_medium"
            android:text="로 가입하기"
            android:textColor="@color/black.white"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/txt_manager"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 오른쪽 화살표 -->
        <ImageView
            android:id="@+id/icon_arrow2"
            android:layout_width="35dp"
            android:layout_height="33dp"
            android:layout_marginEnd="16dp"
            android:src="@drawable/right_arrow"
            android:clickable="false"
            android:focusable="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
