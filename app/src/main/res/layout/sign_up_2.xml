<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/base">

    <!-- 뒤로가기 버튼 -->
    <ImageButton
        android:id="@+id/imageButton"
        android:layout_width="23dp"
        android:layout_height="29dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/icon_back"
        app:tint="@color/gray900_gray50"/>

    <!-- 회원가입 텍스트 -->
    <TextView
        android:id="@+id/sign_up"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="@font/pretendard_bold"
        android:text="회원가입"
        android:letterSpacing="0"
        android:textColor="@color/gray900_gray50"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="@id/imageButton"
        app:layout_constraintStart_toEndOf="@id/imageButton"
        app:layout_constraintTop_toTopOf="@id/imageButton" />

    <!-- 이름 라벨 -->
    <TextView
        android:id="@+id/tv_name_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:fontFamily="@font/pretendard_medium"
        android:text="이름"
        android:letterSpacing="0"
        android:textColor="@color/gray700_gray400"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imageButton" />

    <!-- 이름 입력 필드 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_write_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:textColorHint="@color/et_hint_color"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusTopStart="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_name_label"
        app:boxBackgroundMode="outline"
        app:boxBackgroundColor="@color/white_gray900"
        app:boxStrokeWidth="1dp"
        app:boxStrokeWidthFocused="1dp"
        app:boxStrokeColor="@color/til_stroke"
        app:hintTextColor="@color/et_hint_color">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_name"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            app:boxBackgroundColor="@color/white_gray900"
            android:fontFamily="@font/pretendard_medium"
            android:hint="이름을 입력해주세요"
            android:letterSpacing="0"
            android:inputType="text"
            android:maxLines="1"
            android:padding="20dp"
            android:textCursorDrawable="@null"
            android:textColor="@color/black_white"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 전화번호 라벨 -->
    <TextView
        android:id="@+id/tv_phone_number_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/pretendard_medium"
        android:text="전화번호"
        android:letterSpacing="0"
        android:textColor="@color/gray700_gray400"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_write_name" />

    <!-- 전화번호 입력 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_write_phone_number"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        android:textColorHint="@color/et_hint_color"
        app:boxBackgroundMode="outline"
        app:boxBackgroundColor="@color/white_gray900"
        app:boxStrokeWidth="1dp"
        app:boxStrokeWidthFocused="1dp"
        app:boxStrokeColor="@color/til_stroke"
        app:boxCornerRadiusTopStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusBottomEnd="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/phone_number_button"
        app:layout_constraintTop_toBottomOf="@id/tv_phone_number_label"
        app:layout_constraintHorizontal_weight="7"
        app:hintTextColor="@color/et_hint_color">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_phone_number"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:fontFamily="@font/pretendard_medium"
            android:hint="번호를 입력해주세요"
            android:letterSpacing="0"
            android:textColor="@color/black_white"
            android:padding="20dp"
            android:inputType="phone"
            android:textCursorDrawable="@null"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 인증번호 받기 -->
    <Button
        android:id="@+id/phone_number_button"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginEnd="24dp"
        android:backgroundTint="#F97316"
        android:text="인증번호받기"
        android:letterSpacing="0"
        android:textColor="@color/white_gray950"
        android:textSize="18sp"
        android:fontFamily="@font/pretendard_semibold"
        android:stateListAnimator="@null"
        app:cornerRadius="8dp"
        app:layout_constraintTop_toTopOf="@id/til_write_phone_number"
        app:layout_constraintBottom_toBottomOf="@id/til_write_phone_number"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_weight="3"/>

    <!-- 인증번호 입력 라벨 -->
    <TextView
        android:id="@+id/tv_verify_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/pretendard_medium"
        android:text="인증번호 입력"
        android:letterSpacing="0"
        android:textColor="@color/gray700_gray400"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_write_phone_number" />

    <!-- 인증번호 입력 필드 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_write_verify"
        android:layout_width="0dp"
        android:layout_height="71dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        android:textColorHint="@color/et_hint_color"
        app:boxBackgroundMode="outline"
        app:boxBackgroundColor="@color/white_gray900"
        app:boxStrokeWidth="1dp"
        app:boxStrokeWidthFocused="1dp"
        app:boxStrokeColor="@color/til_stroke"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusTopStart="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/verify_button"
        app:layout_constraintTop_toBottomOf="@id/tv_verify_label"
        app:layout_constraintHorizontal_weight="7"
        app:hintTextColor="@color/et_hint_color">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_verify"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            app:boxBackgroundColor="@color/white_gray900"
            android:fontFamily="@font/pretendard_medium"
            android:hint="인증번호를 입력해주세요"
            android:letterSpacing="0"
            android:inputType="number"
            android:padding="20dp"
            android:textColor="@color/black_white"
            android:textCursorDrawable="@null"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 인증 버튼 -->
    <Button
        android:id="@+id/verify_button"
        android:layout_width="115dp"
        android:layout_height="71dp"
        android:layout_marginEnd="24dp"
        android:backgroundTint="#F97316"
        android:fontFamily="@font/pretendard_semibold"
        android:text="인증"
        android:letterSpacing="0"
        android:textColor="@color/white_gray950"
        android:textSize="18sp"
        android:stateListAnimator="@null"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="@id/til_write_verify"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/til_write_verify"
        app:layout_constraintTop_toTopOf="@id/til_write_verify"
        app:layout_constraintHorizontal_weight="3"/>

    <!-- 성공/에러 메시지 -->
    <LinearLayout
        android:id="@+id/ll_notice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/til_write_verify"
        app:layout_constraintStart_toStartOf="@id/til_write_verify"
        android:layout_marginTop="4dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_notice"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:foregroundGravity="center"
            app:srcCompat="@drawable/ic_success" />

        <TextView
            android:id="@+id/tv_notice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="인증이 완료되었습니다."
            android:letterSpacing="0"
            android:textSize="12sp"
            android:textColor="@color/teal500"
            android:visibility="visible"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <!-- 다음 버튼 -->
    <Button
        android:id="@+id/next_button"
        android:layout_width="0dp"
        android:layout_height="65dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="21dp"
        android:backgroundTint="#F97316"
        android:fontFamily="@font/pretendard_semibold"
        android:text="다음"
        android:letterSpacing="0"
        android:textColor="@color/white_black"
        android:textSize="18sp"
        android:stateListAnimator="@null"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
