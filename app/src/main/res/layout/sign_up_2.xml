<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/base">

    <!-- 뒤로가기 버튼 -->
    <ImageButton
        android:id="@+id/imageButton"
        android:layout_width="23dp"
        android:layout_height="29dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/icon_back"
        app:tint="@color/gray_900.gray_50"/>

    <!-- 회원가입 텍스트 -->
    <TextView
        android:id="@+id/sign_up"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="@font/pretendard_bold"
        android:text="회원가입"
        android:textColor="@color/gray_900.gray_50"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="@id/imageButton"
        app:layout_constraintStart_toEndOf="@id/imageButton"
        app:layout_constraintTop_toTopOf="@id/imageButton" />

    <!-- 이름 라벨 -->
    <TextView
        android:id="@+id/tv_name_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="32dp"
        android:fontFamily="@font/pretendard_medium"
        android:text="이름"
        android:textColor="@color/gray_700.gray_400"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imageButton" />

    <!-- 이름 입력 필드 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_write_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusTopStart="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_name_label">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_name"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            app:boxBackgroundColor="@color/white.gray_900"
            android:backgroundTint="#FFFFFF"
            android:fontFamily="@font/pretendard_medium"
            android:hint="이름을 입력해주세요"
            android:inputType="text"
            android:maxLines="1"
            android:padding="20dp"
            android:textColor="@color/black.white"
            android:textColorHint="@color/gray_500.gray_650" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 인증번호 입력 라벨 -->
    <TextView
        android:id="@+id/tv_verify_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="32dp"
        android:fontFamily="@font/pretendard_medium"
        android:text="인증번호 입력"
        android:textColor="@color/gray_700.gray_400"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_write_name" />

    <!-- 인증번호 입력 필드 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_write_verify"
        android:layout_width="0dp"
        android:layout_height="71dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusTopStart="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/verify_button"
        app:layout_constraintTop_toBottomOf="@id/tv_verify_label">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_verify"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            app:boxBackgroundColor="@color/white.gray_900"
            android:backgroundTint="#FFFFFF"
            android:fontFamily="@font/pretendard_medium"
            android:hint="인증번호를 입력해주세요"
            android:inputType="number"
            android:padding="20dp"
            android:textColor="@color/black.white"
            android:textColorHint="@color/gray_500.gray_650"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 인증 버튼 -->
    <Button
        android:id="@+id/verify_button"
        android:layout_width="115dp"
        android:layout_height="71dp"
        android:layout_marginEnd="16dp"
        android:backgroundTint="#F97316"
        android:fontFamily="@font/pretendard_semibold"
        android:text="인증"
        android:textColor="@color/white.gray_950"
        android:textSize="18sp"
        app:cornerRadius="7dp"
        app:layout_constraintBottom_toBottomOf="@id/til_write_verify"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/til_write_verify"
        app:layout_constraintTop_toTopOf="@id/til_write_verify" />

    <!-- 다음 버튼 -->
    <Button
        android:id="@+id/next_button"
        android:layout_width="0dp"
        android:layout_height="65dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#F97316"
        android:fontFamily="@font/pretendard_semibold"
        android:text="다음"
        android:textColor="@color/white.black"
        android:textSize="18sp"
        app:cornerRadius="7dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
