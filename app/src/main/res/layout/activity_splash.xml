<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/base">

    <!-- 로고 + 타이틀 -->
    <LinearLayout
        android:id="@+id/logoGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="29dp"
            android:layout_height="31dp"
            android:layout_marginEnd="5dp"
            android:src="@drawable/_2026_01_05_15_18_02_removebg_preview"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="중대재해예방 플랫폼"
            android:textSize="24sp"
            android:textColor="#F97316"
            android:fontFamily="@font/clipartkorea_medium"/>
    </LinearLayout>

    <!-- 회원가입 -->
    <Button
        android:id="@+id/btnSignUp"
        android:layout_width="327dp"
        android:layout_height="52dp"
        android:backgroundTint="#F97316"
        android:fontFamily="@font/pretendard_semibold"
        android:text="회원가입"
        android:textColor="@color/white.gray_950"
        android:textSize="18sp"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toTopOf="@id/btnLogin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 로그인 -->
    <Button
        android:id="@+id/btnLogin"
        android:layout_width="327dp"
        android:layout_height="52dp"
        android:layout_marginBottom="30dp"
        android:backgroundTint="@color/base"
        android:fontFamily="@font/pretendard_semibold"
        android:text="로그인"
        android:textColor="#F97316"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="#F97316"
        app:strokeWidth="1dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
