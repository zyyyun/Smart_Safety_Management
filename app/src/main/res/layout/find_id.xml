<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/base">

    <!-- 뒤로가기 버튼 -->
    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="23dp"
        android:layout_height="29dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/icon_back"
        app:tint="@color/gray900_gray50"/>

    <!-- 아이디 찾기 -->
    <TextView
        android:id="@+id/find_id"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="@font/pretendard_bold"
        android:text="아이디 찾기"
        android:letterSpacing="0"
        android:textColor="@color/gray900_gray50"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="@id/backButton"
        app:layout_constraintStart_toEndOf="@id/backButton"
        app:layout_constraintTop_toTopOf="@id/backButton" />

    <!-- 안내 문구 1 -->
    <TextView
        android:id="@+id/txt_message1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/pretendard_bold"
        android:text="아이디가 기억나지 않으세요?"
        android:letterSpacing="0"
        android:textColor="@color/gray900_gray50"
        android:textSize="24sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/find_id" />

    <!-- 안내 문구 2 -->
    <TextView
        android:id="@+id/txt_message2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="5dp"
        android:fontFamily="@font/pretendard_medium"
        android:text="가입 시 등록한 휴대폰 번호로 찾을 수 있습니다."
        android:letterSpacing="0"
        android:textColor="@color/gray700_gray400"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_message1" />

    <!-- 이름 라벨 -->
    <TextView
        android:id="@+id/tv_name_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/pretendard_medium"
        android:text="이름"
        android:letterSpacing="0"
        android:textColor="@color/gray700_gray400"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_message2" />

    <!-- 이름 입력 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_write_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:boxBackgroundMode="outline"
        app:boxBackgroundColor="@color/white_gray900"
        app:boxStrokeWidth="1dp"
        app:boxStrokeWidthFocused="1dp"
        app:boxStrokeColor="@color/til_stroke"
        app:boxCornerRadiusTopStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusBottomEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_name_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_name"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:fontFamily="@font/pretendard_medium"
            android:hint="이름을 입력해주세요"
            android:letterSpacing="0"
            android:textColor="@color/black_white"
            android:textColorHint="@color/et_hint_color"
            android:padding="20dp"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 전화번호 라벨 -->
    <TextView
        android:id="@+id/tv_phone_number_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/pretendard_medium"
        android:text="전화번호"
        android:letterSpacing="0"
        android:textColor="@color/gray700_gray400"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_write_name" />

    <!-- 전화번호 입력 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_write_phone_number"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        app:boxBackgroundMode="outline"
        app:boxBackgroundColor="@color/white_gray900"
        app:boxStrokeWidth="1dp"
        app:boxStrokeWidthFocused="1dp"
        app:boxStrokeColor="@color/til_stroke"
        app:boxCornerRadiusTopStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusBottomEnd="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/phone_number_button"
        app:layout_constraintTop_toBottomOf="@id/tv_phone_number_label">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_phone_number"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:fontFamily="@font/pretendard_medium"
            android:hint="번호를 입력해주세요"
            android:letterSpacing="0"
            android:textColor="@color/black_white"
            android:textColorHint="@color/et_hint_color"
            android:padding="20dp"
            android:inputType="number" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 인증번호 받기 -->
    <Button
        android:id="@+id/phone_number_button"
        android:layout_width="140dp"
        android:layout_height="72dp"
        android:layout_marginEnd="24dp"
        android:backgroundTint="#F97316"
        android:text="인증번호받기"
        android:letterSpacing="0"
        android:textColor="@color/white_gray950"
        android:textSize="18sp"
        android:fontFamily="@font/pretendard_semibold"
        android:stateListAnimator="@null"
        app:cornerRadius="7dp"
        app:layout_constraintTop_toTopOf="@id/til_write_phone_number"
        app:layout_constraintBottom_toBottomOf="@id/til_write_phone_number"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 다음 버튼 -->
    <Button
        android:id="@+id/next_button"
        android:layout_width="0dp"
        android:layout_height="65dp"
        android:layout_marginBottom="64dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:backgroundTint="#F97316"
        android:text="다음"
        android:letterSpacing="0"
        android:textColor="@color/white_black"
        android:textSize="18sp"
        android:fontFamily="@font/pretendard_semibold"
        android:stateListAnimator="@null"
        app:cornerRadius="7dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 비밀번호 찾기 -->
    <TextView
        android:id="@+id/tv_find_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="21dp"
        android:fontFamily="@font/pretendard_medium"
        android:text="비밀번호를 잊어버렸어요"
        android:letterSpacing="0"
        android:textColor="@color/gray400_gray700"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/next_button"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
