<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.appbar.MaterialToolbar xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/top_app_bar"
    android:layout_width="match_parent"
    android:layout_height="?attr/actionBarSize"
    android:background="@color/orange500_gray950"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    app:contentInsetStart="0dp"
    app:contentInsetEnd="0dp"
    app:elevation="0dp">

    <!-- 좌측: 로고 + 타이틀 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="23dp"
            android:contentDescription="로고"
            android:src="@drawable/_2026_01_05_15_18_02_removebg_preview"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/clipartkorea_medium"
            android:text="중대재해예방 플랫폼"
            android:letterSpacing="0"
            android:textColor="@color/white"
            android:textSize="18sp"/>
    </LinearLayout>

    <!-- 우측: 아이콘 영역 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clipChildren="false">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- 알림 버튼 -->
            <ImageButton
                android:id="@+id/btn_alarm"
                android:layout_width="18dp"
                android:layout_height="19dp"
                android:layout_marginEnd="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="알림"
                android:scaleType="centerInside"
                android:src="@drawable/alarm"
                app:tint="@color/white" />

            <!-- 새 알림 점 -->
            <View
                android:id="@+id/view_alarm_dot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginTop="-3dp"
                android:layout_gravity="end|top"
                android:background="@drawable/bg_alarm_dot"
                android:visibility="gone"/>
        </FrameLayout>

        <!-- 설정 버튼 -->
        <ImageButton
            android:id="@+id/btn_setting"
            android:layout_width="20dp"
            android:layout_height="19dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="설정"
            android:src="@drawable/setting"
            android:scaleType="centerInside"
            app:tint="@color/white" />
    </LinearLayout>

</com.google.android.material.appbar.MaterialToolbar>
