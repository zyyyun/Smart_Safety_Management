<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/orange550_gray950">

    <!-- ===================== -->
    <!-- 고정 상단바 -->
    <!-- ===================== -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="0dp"
        android:outlineProvider="none"
        android:fitsSystemWindows="true">

        <include
            android:id="@+id/top_bar"
            layout="@layout/view_top_app_bar" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- 프로필바 -->
    <include
        android:id="@+id/profile_bar"
        layout="@layout/view_profile_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="?attr/actionBarSize"
        android:elevation="0dp" />

    <!-- ===================== -->
    <!-- 스크롤 영역 (본문) -->
    <!-- ===================== -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/home_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="135dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- 본문 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:backgroundTint="@color/orange500_gray950"
                app:cardElevation="0dp"
                app:cardUseCompatPadding="false"
                app:cardPreventCornerOverlap="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_round_top_card"
                    android:orientation="vertical"
                    android:paddingBottom="16dp"
                    android:paddingTop="24dp">

                    <!-- Phase 7 / 07-03 BRIDGE-01 — J2208A 워치 카드 (ComposeView 임베드) -->
                    <!-- profile_bar 아래, 섹션 1 위. setContent 는 HomeWorkerActivity.setupWatchCard() -->
                    <androidx.compose.ui.platform.ComposeView
                        android:id="@+id/watch_card_compose"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="24dp"
                        android:layout_marginBottom="16dp" />

                    <!-- Phase 9 / 09-03 TBM-02 — worker TBM 카드 (D-07)
                         watch_card_compose 아래 위치.
                         setContent 는 HomeWorkerActivity.setupTbmCard() -->
                    <androidx.compose.ui.platform.ComposeView
                        android:id="@+id/tbm_card_compose"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="24dp"
                        android:layout_marginBottom="16dp" />

                    <!-- 섹션 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp">

                        <TextView
                            android:id="@+id/tv_worker_day"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="2026년 5월 7일"
                            android:fontFamily="@font/pretendard_bold"
                            android:textSize="24dp"
                            android:letterSpacing="0"
                            android:layout_marginBottom="16dp"
                            android:textColor="@color/gray900_gray50"/>

                        <include 
                            android:id="@+id/list_header"
                            layout="@layout/view_list_header"/>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="293dp"
                            android:layout_marginTop="24dp">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rv_daily_check"
                                android:layout_width="match_parent"
                                android:layout_height="293dp"
                                android:overScrollMode="never"/>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="24dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_list_fade_edge"/>
                        </FrameLayout>
                    </LinearLayout>

                    <!-- 구분선 1 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="40dp"
                        android:layout_marginBottom="40dp"
                        android:background="@color/gray100_gray950" />

                    <!-- 섹션 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="조치요청"
                            android:fontFamily="@font/pretendard_semibold"
                            android:textSize="18dp"
                            android:textColor="@color/gray900_gray50"
                            android:letterSpacing="0"/>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="293dp"
                            android:layout_marginTop="24dp">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rv_worker_event"
                                android:layout_width="match_parent"
                                android:layout_height="293dp"
                                android:overScrollMode="never"/>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="24dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_list_fade_edge" />
                        </FrameLayout>
                    </LinearLayout>

                    <!-- 구분선 2 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="40dp"
                        android:layout_marginBottom="40dp"
                        android:background="@color/gray100_gray950" />

                    <!-- 섹션 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp">

                        <include
                            android:id="@+id/view_emergency"
                            layout="@layout/view_emergecy_contact"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>