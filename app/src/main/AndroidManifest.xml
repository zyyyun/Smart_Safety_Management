<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.example.smart_safety_management">

    <!--지도-->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />


    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Smart_Safety_Management">

        <!-- Splash 화면 -->
        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 회원가입 화면1 (근로자 or 관리자 선택) -->
        <activity
            android:name=".SignUp1Activity" />

        <!-- 회원가입 화면2 (본인인증) -->
        <activity
            android:name=".SignUp2Activity" />

        <!-- 회원가입 화면3 (아이디, 비밀번호 입력)-->
        <activity
            android:name=".SignUp3Activity" />

        <!-- 회원가입 화면4 (가입완료)-->
        <activity
            android:name=".SignUp4Activity" />

        <!-- 로그인 화면 -->
        <activity
            android:name=".LogInActivity" />

        <!-- 아이디 찾기 화면 -->
        <activity
            android:name=".FindIdActivity" />

        <!-- 아이디 찾기 성공 화면 -->
        <activity android:name=".FoundIdActivity" />

        <!-- 비밀번호 찾기 화면 -->
        <activity android:name=".FindPasswordActivity" />

        <!-- 비밀번호 수정 화면 -->
        <activity android:name=".ChangePasswordActivity"/>
        
        <!-- 비밀번호 수정 완료 화면 -->
        <activity android:name=".PasswordChangedActivity"/>

        <!-- 메인 홈 화면 -->
        <activity android:name=".HomeActivity"/>
        <activity android:name=".HomeWorkerActivity"/>

        <!-- 일일안전점검 화면 -->
        <activity
            android:name=".DailyDetailActivity"
            android:exported="false"/>

        <!-- 월별로 보기 화면 -->
        <activity
            android:name=".MonthlyListActivity"
            android:exported="false" />

        <!-- 조치 결과 등록 화면(근로자) -->
        <activity
            android:name=".ActionDetailActivity"
            android:exported="false"/>

        <!-- 알림 화면 -->
        <activity
            android:name=".NoticeActivity"
            android:exported="false" />

        <!-- 일일점검리스트 화면 -->
        <activity
            android:name=".DailyListActivity"
            android:exported="false"/>

        <!-- 설정 화면 -->
        <activity
            android:name=".SettingActivity"
            android:exported="false"/>"
        <activity
            android:name=".SettingWorkerActivity"
            android:exported="false"/>

        <!-- 설정 - 초대코드 입력 화면 -->
        <activity
            android:name=".SettingInviteCodeActivity"
            android:exported="false"/>

        <!-- 설정 - 내정보 화면 -->
        <activity android:name=".SettingProfileActivity"
            android:exported="false"/>

        <!-- AI 이벤트 감지 화면 -->
        <activity
            android:name=".AIEventActivity"
            android:exported="true"/>

        <!-- 이력화면 -->
        <activity
            android:name=".HistoryActivity"
            android:exported="true" />

        <!-- 설정 - 비밀번호 수정 화면 -->
        <activity
            android:name=".SettingChangePasswordActivity"
            android:exported="false"/>

        <!-- 설정 - 현장 만들기 화면 -->
        <activity
            android:name=".SettingCreateWorkplaceActivity"
            android:exported="false"/>

        <!-- 실시간 상황 화면 -->
        <activity android:name=".screens.realtime.RealTimeActivity" />

        <!-- 위치정보 화면 -->
        <activity android:name=".screens.location.LocationActivity" />

        <!-- 설정 - 초대하기 화면 -->
        <activity
            android:name=".SettingInviteActivity"
            android:exported="false"/>

        <!-- 설정 - 초대하기 - 연락처 불러오기 화면 -->
        <activity
            android:name=".SettingInvitePhonenumberActivity"
            android:exported="false"/>

        <!-- 설정 - 초대하기 - 초대취소 화면 -->
        <activity
            android:name=".SettingInviteCancelActivity"
            android:exported="false"/>

        <!-- 설정 - 인원관리 화면 -->
        <activity
            android:name=".SettingPeopleManagementActivity"
            android:exported="false"/>

        <!-- 설정 - CCTV관리 화면 -->
        <activity
            android:name=".SettingCctvManagementActivity"
            android:exported="false"/>

        <!-- 설정 - 기기관리 화면 -->
        <activity
            android:name=".SettingDeviceManagementActivity"
            android:exported="false"/>
        <activity
            android:name=".DeviceManageWorkerActivity"
            android:exported="false"/>

        <!-- 근로자 - 비상연락리스트 화면 -->
        <activity android:name=".EmergencyContactActivity"
            android:exported="false"/>

        <!-- 현장위치 설정 화면 -->
        <activity
            android:name=".SettingWorkplaceLocationActivity"
            android:exported="false" />

    </application>

</manifest>
