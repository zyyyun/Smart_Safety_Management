<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.example.smart_safety_management">

    <!-- 권한 설정 -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Foreground Service 권한 추가 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 2026-05-21 — Sprint A.2.1: Drift X3 페어링용 폰 WiFi SSID 자동 감지 -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- 2026-05-21 — Sprint A.1.1: J2208A 워치 BLE master (PC bleak 의존성 제거) -->
    <!-- Android 12+ runtime BLE 권한 -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- Android 11- backwards compat -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />
    <!-- Android 14+ BLE FGS subtype -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />


    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />


    <application
        android:name=".MyApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="중대재해예방 플랫폼"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:hardwareAccelerated="true"
        android:theme="@style/Theme.Smart_Safety_Management">



        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Splash 화면 -->
        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 회원가입 화면1 (근로자 or 관리자 선택) -->
        <activity
            android:name=".SignUp1Activity" />

        <!-- 회원가입 화면2 (본인인증) -->
        <activity
            android:name=".SignUp2Activity" />

        <!-- 회원가입 화면3 (아이디, 비밀번호 입력)-->
        <activity
            android:name=".SignUp3Activity" />

        <!-- 회원가입 화면4 (가입완료)-->
        <activity
            android:name=".SignUp4Activity" />

        <!-- 로그인 화면 -->
        <activity
            android:name=".LogInActivity" />

        <!-- 아이디 찾기 화면 -->
        <activity
            android:name=".FindIdActivity" />

        <!-- 아이디 찾기 성공 화면 -->
        <activity android:name=".FoundIdActivity" />

        <!-- 비밀번호 찾기 화면 -->
        <activity android:name=".FindPasswordActivity" />

        <!-- 비밀번호 수정 화면 -->
        <activity android:name=".ChangePasswordActivity"/>

        <!-- 비밀번호 수정 완료 화면 -->
        <activity android:name=".PasswordChangedActivity"/>

        <!-- 메인 홈 화면 -->
        <activity
            android:name=".HomeActivity"
            android:theme="@style/Theme.Smart_Safety_Management.Status.Orange" />
        <activity
            android:name=".HomeWorkerActivity"
            android:theme="@style/Theme.Smart_Safety_Management.Status.Orange" />

        <!-- 일일안전점검 화면 -->
        <activity
            android:name=".DailyDetailActivity"
            android:exported="false"/>

        <!-- 월별로 보기 화면 -->
        <activity
            android:name=".MonthlyListActivity"
            android:exported="false" />

        <!-- 조치 결과 등록 화면(근로자) -->
        <activity
            android:name=".ActionDetailActivity"
            android:exported="false"/>

        <!-- 알림 화면 -->
        <activity
            android:name=".NoticeActivity"
            android:exported="false" />

        <!-- 일일점검리스트 화면 -->
        <activity
            android:name=".DailyListActivity"
            android:exported="false"/>

        <!-- 설정 화면 -->
        <activity
            android:name=".SettingActivity"
            android:exported="false"/>
        <activity
            android:name=".SettingWorkerActivity"
            android:exported="false"/>

        <!-- 설정 - 초대코드 입력 화면 -->
        <activity
            android:name=".SettingInviteCodeActivity"
            android:exported="false"/>

        <!-- 설정 - 내정보 화면 -->
        <activity android:name=".SettingProfileActivity"
            android:exported="false"/>

        <!-- AI 이벤트 감지 화면 -->
        <activity
            android:name=".AIEventActivity"
            android:exported="true" />

        <!-- 이력화면 -->
        <activity
            android:name=".HistoryActivity"
            android:exported="true"
            android:theme="@style/Theme.Smart_Safety_Management.Status.Orange" />

        <!-- 설정 - 비밀번호 수정 화면 -->
        <activity
            android:name=".SettingChangePasswordActivity"
            android:exported="false"/>

        <!-- 설정 - 현장 만들기 화면 -->
        <activity
            android:name=".SettingCreateWorkplaceActivity"
            android:exported="false"/>

        <!-- 실시간 상황 화면 -->
        <activity android:name=".screens.realtime.RealTimeActivity" />

        <!-- 위치정보 화면 -->
        <activity android:name=".screens.location.LocationActivity" />

        <!-- 설정 - 초대하기 화면 -->
        <activity
            android:name=".SettingInviteActivity"
            android:exported="false"/>

        <!-- 설정 - 초대하기 - 연락처 불러오기 화면 -->
        <activity
            android:name=".SettingInvitePhonenumberActivity"
            android:exported="false"/>

        <!-- 설정 - 초대하기 - 초대취소 화면 -->
        <activity
            android:name=".SettingInviteCancelActivity"
            android:exported="false"/>

        <!-- 설정 - 인원관리 화면 -->
        <activity
            android:name=".SettingPeopleManagementActivity"
            android:exported="false"/>

        <!-- 설정 - CCTV관리 화면 -->
        <activity
            android:name=".SettingCctvManagementActivity"
            android:exported="false"/>

        <activity
            android:name=".SettingOpsCatalogActivity"
            android:exported="false"/>

        <!-- 설정 - 기기관리 화면 -->
        <activity
            android:name=".SettingDeviceManagementActivity"
            android:exported="false"/>
        <activity
            android:name=".DeviceManageWorkerActivity"
            android:exported="false"/>

        <!-- 근로자 - 비상연락리스트 화면 -->
        <activity android:name=".EmergencyContactActivity"
            android:exported="false"/>

        <!-- 현장위치 설정 화면 -->
        <activity
            android:name=".SettingWorkplaceLocationActivity"
            android:exported="false" />


        <activity
            android:name=".ActionDetailWorkerActivity"
            android:exported="false"/>


        <!-- ✅ 카카오 SDK 키 대표 Default Native AppKey 넣는곳-->
        <meta-data
            android:name="com.kakao.sdk.AppKey"
            android:value="${kakaoNativeAppKey}" />

        <!-- ✅ 카카오 VectorMap 키 (추가) 대표 Default Native AppKey 넣는곳 -->
        <meta-data
            android:name="com.kakao.vectormap.APP_KEY"
            android:value="${kakaoNativeAppKey}" />

        <!-- 위치 전송 Foreground Service 등록 -->
        <service
            android:name=".LocationService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />

        <service
            android:name=".watch.ble.WatchBleForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- 2026-05-22 — feature_rtps_test / plan v3.1 / R3a:
             RtspPocService 폐지. R3 (LibVLC + takeSnapshot) 가 LibVLC Android Java
             wrapper 의 takeSnapshot 미노출로 compile fail → R3a (LibVLC + TextureView
             + lifecycleScope) 로 전환. capture 가 HomeActivity bound 라 Service 무용. -->

        <!-- ✅ FCM 서비스 등록 -->
        <service
            android:name=".MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <activity android:name=".FireAlarmManageActivity" />
        <activity android:name=".screens.afci.ArcBreakerManageActivity" />
        <activity android:name=".SettingWorkplaceAreaActivity" />

        <!-- Phase 7 / 07-03 BRIDGE-02 — 워치 알림 전용 화면 (AIEventActivity 와 별도) -->
        <activity
            android:name=".SafetyAlertsActivity"
            android:exported="false"
            android:label="워치 알림" />

        <!-- Phase 9 / 09-03 TBM-02 — manager TBM 대시보드 (D-06, T-9-13 manager only) -->
        <activity
            android:name=".TbmDashboardActivity"
            android:exported="false"
            android:label="TBM 대시보드" />

        <!-- Phase 9 / 09-03 TBM-02 — worker TBM 가이드 (D-07) -->
        <activity
            android:name=".TbmWorkerActivity"
            android:exported="false"
            android:label="TBM 가이드" />

        <!-- 2026-05-21 — 워치 신체 정보 상세 화면 (WatchMiniCardComposable tap) -->
        <activity
            android:name=".watch.WatchDetailActivity"
            android:exported="false"
            android:label="내 신체 정보" />

        <!-- 2026-05-21 — Sprint A.2: Drift X3 카메라 QR 페어링 + 등록 -->
        <activity
            android:name=".camera.CameraPairingActivity"
            android:exported="false"
            android:label="카메라 페어링" />
    </application>

</manifest>
