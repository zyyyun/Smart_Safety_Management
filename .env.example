# J2208A BLE 클라이언트 환경변수 (per CONTEXT.md D-12)
#
# 실제 .env 파일은 .gitignore 차단 — 절대 커밋 금지.
# 운영 환경에서는 OS env 또는 process manager (systemd, supervisord) 로 주입 권장.
#
# 사용 예 (Windows PowerShell):
#   Copy-Item .env.example .env
#   # .env 편집 후
#   python scripts/j2208a_sensor_reader.py
#
# 사용 예 (bash/zsh):
#   cp .env.example .env
#   set -a && source .env && set +a
#   python scripts/j2208a_sensor_reader.py

# ──────────────────────────────────────────
# Supabase (j2208a/supabase_writer.py + Edge Function 호출)
# ──────────────────────────────────────────
# Project URL — Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# service_role key (RLS 우회) — Supabase Dashboard → Settings → API → service_role
# 절대 클라이언트 코드/저장소에 노출 금지. Edge Function Authorization 헤더로도 사용.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR-SERVICE-ROLE-KEY

# (선택) anon key — Edge Function curl smoke test 용. 프로덕션 BLE 클라이언트는 service_role 만 사용.
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR-ANON-KEY

# ──────────────────────────────────────────
# J2208A 디바이스 매핑 (010_watch_pipeline.sql 시드)
# ──────────────────────────────────────────
# devices.device_id (010 마이그레이션 시드 = 1 for testuser1 / MAC 21:02:02:06:01:69)
TEST_DEVICE_ID=1

# profiles.user_id — FCM 푸시 수신자
TEST_USER_ID=testuser1
