# Supabase 연결 정보
SUPABASE_URL=https://xbjqxnvemcqubjfflain.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# system Edge Function 호출용 공유 비밀 (supabase secrets set SYSTEM_AGENT_SECRET=... 로 동일 값 등록 필요)
SYSTEM_AGENT_SECRET=your-shared-secret-here

# 스냅샷 스토리지 설정
CAMERA_CAPTURES_BUCKET=camera-captures

# 스냅샷 스케줄 설정 (분 단위)
SNAPSHOT_INTERVAL_MIN=10

# 임시 파일 디렉토리 (생략 시 OS 기본 temp)
SNAPSHOT_TMP_DIR=

# FFmpeg 경로 (PATH 등록돼 있으면 'ffmpeg' 그대로)
FFMPEG_BIN=ffmpeg

# 로그 레벨 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# ── 쓰러짐 감지 (Next-3 / LP-2)
# YOLOv7-w6-pose 가중치 파일 경로 (절대경로 권장)
FALL_MODEL_WEIGHTS=D:/2025_산업안전/산업안전/모델 7종/쓰러짐 탐지/yolov7-w6-pose.pt
# 쓰러짐 감지 주기 (분)
FALL_INTERVAL_MIN=1
# 카메라당 연속 감지 방지 쿨타임 (분)
FALL_COOLDOWN_MIN=10
# 연산 장치: auto (CUDA 있으면 GPU, 없으면 CPU) / cpu / cuda / cuda:0
FALL_DEVICE=auto
# YOLOv7 objectness/IoU NMS 임계값
FALL_CONF_THRES=0.25
FALL_IOU_THRES=0.65
# 입력 해상도 (letterbox). 960 권장 (원본 train 기준)
FALL_IMG_SIZE=960
# 감지 대상 camera_id 쉼표 구분. 예: "2,5". 비워두면 감지 미실행
FALL_ENABLED_CAMERA_IDS=2
# (선택) 레퍼런스 영상 데모용 — FFmpeg input seek 초. RTSP 라이브 스트림에서는 비워둘 것
# FALL_DEMO_SEEK_SEC=119.5
